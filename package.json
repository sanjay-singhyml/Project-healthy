{
  "name": "project-health",
  "version": "1.0.2",
  "description": "AI-powered health score for software repositories - CLI tool with 8 parallel analysis modules",
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin",
    "readme.md"
  ],
  "bin": {
    "ph": "./bin/ph.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:proxy": "node --import tsx src/proxy/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "pkg": "npx @yao-pkg/pkg . --targets node18-linux-x64,node18-macos-x64,node18-macos-arm64,node18-win-x64 --output ph-binaries",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "health",
    "analysis",
    "code-quality",
    "security",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@gitbeaker/rest": "^41.0.0",
    "@inquirer/prompts": "^8.3.2",
    "@octokit/rest": "^21.0.2",
    "ajv": "^8.17.1",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "debug": "^4.4.3",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "express": "^4.21.0",
    "fast-xml-parser": "^5.5.8",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "simple-git": "^3.27.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@yao-pkg/pkg": "^6.14.1",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}

# Project Health - Environment Variables

# =============================================================================
# AI Backend Configuration (Optional - for self-hosted proxy)
# =============================================================================

# Project Health Backend URL
# Default: https://api.projecthealth.io/v1 (hosted backend - no setup required)
# For self-hosted proxy, set to your proxy URL (e.g., http://localhost:3000)
PROJECT_HEALTH_BACKEND_URL="http://localhost:3000/v1"

# MegaLLM API Key - ONLY required for self-hosted proxy
# Leave empty to use hosted backend (recommended for zero-config UX)
# Get your API key from https://megallm.io
MEGALLM_API_KEY=

# MegaLLM Base URL (usually https://ai.megallm.io/v1)
MEGALLM_BASE_URL=https://ai.megallm.io/v1

# AI Model to use (never hardcode - always from .env)
# Default: claude-sonnet-4-6
MEGALLM_MODEL=openai-gpt-oss-120b

# =============================================================================
# Optional: Proxy Configuration
# =============================================================================

# Max tokens per request (default: 60000)
MEGALLM_MAX_TOKENS=240000

# Temperature for AI responses (default: 0.7)
MEGALLM_TEMPERATURE=0.7

# Stream AI responses (default: true)
MEGALLM_STREAM=true

# Rate limit requests per minute (default: 60)
RATE_LIMIT_RPM=70

# Proxy server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# =============================================================================
# Optional: GitHub Integration
# =============================================================================

# GitHub Personal Access Token
# Required for: ph review, ph brief, M-01 (CI/CD), M-06 (PR Complexity)
# Get one at: https://github.com/settings/tokens/new?scopes=repo,read:org,actions:read
GITHUB_TOKEN=ghp_....xxxxxxxxxxxxxxxx

# =============================================================================
# Optional: GitLab Integration
# =============================================================================

# GitLab Personal Access Token
# Required for: M-01 (CI/CD), M-06 (PR Complexity) on GitLab
GITLAB_TOKEN=your_gitlab_token_here

# =============================================================================
# Optional: Security Scanning
# =============================================================================

# Snyk API Token (optional - premium feature)
# Required for: M-05 (Dependency Security) with Snyk
SNYK_TOKEN=your_snyk_token_here

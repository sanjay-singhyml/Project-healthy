# Server Configuration
PORT=3000

# Authentication (Required)
# Keep this secret! Used to validate JWT tokens from CLI clients.
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# AI Configuration (Required)
# The API key from MegaLLM or OpenAI
MEGALLM_API_KEY=your-api-key-here

# AI Overrides (Optional)
MEGALLM_MODEL=openai-gpt-oss-20b
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MEGALLM_MAX_TOKENS=60000
MEGALLM_TEMPERATURE=0.7

# Rate Limiting
RATE_LIMIT_RPM=60

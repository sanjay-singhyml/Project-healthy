# =============================================================================
# Project Health Backend — Environment Variables
# =============================================================================

# Server
PORT=3000
NODE_ENV=production

# AI Provider
MEGALLM_API_KEY=sk-your-api-key-here
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MEGALLM_MODEL=claude-sonnet-4-6
MEGALLM_MAX_TOKENS=60000
MEGALLM_TEMPERATURE=0.7
MEGALLM_TIMEOUT=120000

# Rate Limiting
RATE_LIMIT_RPM=60
